# gitignore policy: secrets, machine-specific, and reproducible build output.

# ── Secrets ────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# Keys, certs, signing material
*.pem
*.key
*.p8
*.p12
*.crt
*.mobileprovision

# Service-account credentials
firebase-adminsdk-*.json

# Firebase CLI local cache (emulator state, deploy history, etc.)
.firebase/
serviceAccountKey.json
secrets.json

# Cloudflare Wrangler local auth + dev vars
.wrangler/
ai-proxy/.dev.vars

# ── Reproducible build artifacts ──────────────────────────────────────────
node_modules/
dist/
ai-proxy/node_modules/

# iOS build output (keep ios/App/ source, ignore generated)
ios/build/
ios/App/Pods/
ios/App/Podfile.lock
ios/DerivedData/

# Archives + installers
*.ipa
*.xcarchive
*.dSYM.zip

# ── Private / machine-specific ─────────────────────────────────────────────
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
android/local.properties
.idea/
.vscode/

# Claude Code: per-user settings + runtime state (committed: CLAUDE.md, skills/, memory/)
.claude/settings.local.json
.claude/state/
.claude/scheduled_tasks*

# Local visual-verification harness — Playwright screenshots, throwaway scripts,
# patched dist outputs. Never committed; kept for fast re-runs during dev.
.verify-tmp/

# Playwright test runner output
test-results/
playwright-report/
playwright/.cache/

# Private business / legal / formation docs. NEVER commit these.
private/

# ── OS metadata ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
